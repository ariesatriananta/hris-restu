{
  "name": "@hris-restu/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test": "vitest run --config vitest.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:seed-reference": "node --env-file=.env --import tsx src/scripts/seed-reference.ts",
    "db:seed-demo": "node --env-file=.env --import tsx src/scripts/seed-demo-employees.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "jose": "^6.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4"
  }
}
